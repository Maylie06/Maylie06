        "all_paths  = np.array(all_paths)\n",
        "all_labels = np.array(all_labels)\n",
        "NUM_CLASSES = len(class_names)\n",
        "print(f\"\\nTotal: {len(all_paths)} | Classes: {class_names}\")\n",
        "\n",
        "# --- Cell 4: Dataset ---\n",
        "import torch, torchvision.transforms as T\n",
        "from torch.utils.data import Dataset, DataLoader\n",
        "from PIL import Image\n",
        "\n",
        "class FamachaDataset(Dataset):\n",
        "    def __init__(self, paths, labels, transform=None):\n",
        "        self.paths=paths; self.labels=labels; self.transform=transform\n",
        "    def __len__(self): return len(self.paths)\n",
        "    def __getitem__(self, idx):\n",
        "        img = Image.open(self.paths[idx]).convert(\"RGB\")\n",
        "        if self.transform: img = self.transform(img)\n",
        "        return img, self.labels[idx]\n",
        "\n",
        "MEAN=[0.485,0.456,0.406]; STD=[0.229,0.224,0.225]\n",
        "train_tf = T.Compose([T.Resize((256,256)), T.RandomHorizontalFlip(),\n",
        "                      T.ColorJitter(0.2,0.2,0.2), T.ToTensor(), T.Normalize(MEAN,STD)])\n",
        "val_tf   = T.Compose([T.Resize((256,256)), T.ToTensor(), T.Normalize(MEAN,STD)])\n",
        "\n",
        "# --- Cell 5: Nested CV ---\n",
        "import torch.nn as nn, timm\n",
        "from sklearn.model_selection import StratifiedKFold\n",
        "from tqdm import tqdm\n",
        "\n",
        "BATCH=8; EPOCHS=5; LR=1e-4; OUTER_K=5; INNER_K=3\n",
        "DEVICE = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
        "print(\"Device:\", DEVICE)\n",
        "\n",
        "def build_model(num_classes):\n",
        "    return timm.create_model(\"mobilevitv2_100.cvnets_in1k\",\n",
        "                              pretrained=True, num_classes=num_classes)\n",
        "\n",
        "def train_one_epoch(model, loader, optimizer, criterion, device):\n",
        "    model.train()\n",
        "    total_loss, correct, total = 0, 0, 0\n",
        "    for imgs, labels in loader:\n",
        "        imgs, labels = imgs.to(device), labels.to(device)\n",
        "        optimizer.zero_grad()\n",
        "        out  = model(imgs)\n",
        "        loss = criterion(out, labels)\n",
        "        loss.backward(); optimizer.step()\n",
        "        total_loss += loss.item()*imgs.size(0)\n",
        "        correct    += (out.argmax(1)==labels).sum().item()\n",
        "        total      += imgs.size(0)\n",
        "    return total_loss/total, correct/total\n",
        "\n",
        "def evaluate(model, loader, device):\n",
        "    model.eval()\n",
        "    correct, total = 0, 0\n",
        "    with torch.no_grad():\n",
        "        for imgs, labels in loader:\n",
        "            imgs, labels = imgs.to(device), labels.to(device)\n",
        "            correct += (model(imgs).argmax(1)==labels).sum().item()\n",
        "            total   += imgs.size(0)\n",
        "    return correct/total\n",
        "\n",
        "outer_cv = StratifiedKFold(n_splits=OUTER_K, shuffle=True, random_state=42)\n",
        "inner_cv = StratifiedKFold(n_splits=INNER_K, shuffle=True, random_state=7)\n",
        "outer_accs = []\n",
        "\n",
        "print(f\"\\n{'='*60}\\nMobileViT-v2-1.0 | Nested CV (outer={OUTER_K}, inner={INNER_K})\\n{'='*60}\")\n",
        "\n",
        "for outer_fold, (trainval_idx, test_idx) in enumerate(\n",
        "        outer_cv.split(all_paths, all_labels), 1):\n",
        "    print(f\"\\n── Outer Fold {outer_fold}/{OUTER_K} ──\")\n",
        "    tv_paths, tv_labels = all_paths[trainval_idx], all_labels[trainval_idx]\n",
        "    te_paths, te_labels = all_paths[test_idx],     all_labels[test_idx]\n",
        "\n",
        "    inner_val_accs = []\n",
        "    for inner_fold, (tr_idx, val_idx) in enumerate(\n",
        "            inner_cv.split(tv_paths, tv_labels), 1):\n",
        "        tr_ds  = FamachaDataset(tv_paths[tr_idx],  tv_labels[tr_idx],  train_tf)\n",
        "        val_ds = FamachaDataset(tv_paths[val_idx], tv_labels[val_idx], val_tf)\n",
        "        tr_ld  = DataLoader(tr_ds,  batch_size=BATCH, shuffle=True,  num_workers=2)\n",
        "        val_ld = DataLoader(val_ds, batch_size=BATCH, shuffle=False, num_workers=2)\n",
        "        model     = build_model(NUM_CLASSES).to(DEVICE)\n",
        "        optimizer = torch.optim.AdamW(model.parameters(), lr=LR, weight_decay=0.01)\n",
        "        criterion = nn.CrossEntropyLoss()\n",
        "        for ep in range(1, EPOCHS+1):\n",
        "            train_one_epoch(model, tr_ld, optimizer, criterion, DEVICE)\n",
        "        val_acc = evaluate(model, val_ld, DEVICE)\n",
        "        inner_val_accs.append(val_acc)\n",
        "        print(f\"   Inner {inner_fold}/{INNER_K} → Val Acc: {val_acc:.4f}\")\n",
        "    print(f\"   Inner mean: {np.mean(inner_val_accs):.4f} ± {np.std(inner_val_accs):.4f}\")\n",
        "\n",
        "    full_tr_ds = FamachaDataset(tv_paths, tv_labels, train_tf)\n",
        "    te_ds      = FamachaDataset(te_paths, te_labels, val_tf)\n",
        "    full_tr_ld = DataLoader(full_tr_ds, batch_size=BATCH, shuffle=True,  num_workers=2)\n",
        "    te_ld      = DataLoader(te_ds,      batch_size=BATCH, shuffle=False, num_workers=2)\n",
        "    model     = build_model(NUM_CLASSES).to(DEVICE)\n",
        "    optimizer = torch.optim.AdamW(model.parameters(), lr=LR, weight_decay=0.01)\n",
        "    criterion = nn.CrossEntropyLoss()\n",
        "    for ep in tqdm(range(1, EPOCHS+1), desc=f\"  Outer {outer_fold} retraining\"):\n",
        "        train_one_epoch(model, full_tr_ld, optimizer, criterion, DEVICE)\n",
        "    test_acc = evaluate(model, te_ld, DEVICE)\n",
        "    outer_accs.append(test_acc)\n",
        "    print(f\"  ✅ Outer Fold {outer_fold} Test Acc: {test_acc:.4f}\")\n",
        "\n",
        "print(f\"\\n{'='*60}\")\n",
        "print(\"MobileViT-v2-1.0 Nested CV Results (5 outer folds)\")\n",
        "print(f\"  Fold accs : {[f'{a:.4f}' for a in outer_accs]}\")\n",
        "print(f\"  Mean ± Std: {np.mean(outer_accs):.4f} ± {np.std(outer_accs):.4f}\")\n",
        "print(f\"{'='*60}\")"
