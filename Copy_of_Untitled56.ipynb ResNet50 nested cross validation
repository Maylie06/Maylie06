        "# ============================================================\n",
        "# ResNet-50 — Nested 5-Fold Cross-Validation\n",
        "# Famacha/Biochar Dataset (COCO-Segmentation format)\n",
        "# ============================================================\n",
        "\n",
        "# --- Cell 1: Install ---\n",
        "!pip install roboflow torch torchvision pycocotools tqdm scikit-learn\n",
        "\n",
        "# --- Cell 2: Download dataset ---\n",
        "from roboflow import Roboflow\n",
        "\n",
        "rf = Roboflow(api_key=\"0tMzITXXIyplNchzEkbb\")\n",
        "project = rf.workspace(\"famacha-1shsw\").project(\"biochar-famacha_sam_copy\")\n",
        "version = project.version(4)\n",
        "dataset = version.download(\"coco-segmentation\")\n",
        "\n",
        "DATASET_PATH = dataset.location\n",
        "print(\"Dataset path:\", DATASET_PATH)\n",
        "\n",
        "# --- Cell 3: Parse COCO → flat image list with labels ---\n",
        "import os, json\n",
        "import numpy as np\n",
        "from pathlib import Path\n",
        "\n",
        "def load_coco_split(dataset_path, split=\"train\"):\n",
        "    \"\"\"\n",
        "    Returns:\n",
        "        image_paths : list of absolute image path strings\n",
        "        labels      : list of integer class IDs (from first annotation per image)\n",
        "        class_names : list of class name strings\n",
        "    \"\"\"\n",
        "    ann_file = None\n",
        "    for candidate in [\n",
        "        os.path.join(dataset_path, split, \"_annotations.coco.json\"),\n",
        "        os.path.join(dataset_path, split, \"annotations.json\"),\n",
        "        os.path.join(dataset_path, f\"annotations/instances_{split}2017.json\"),\n",
        "    ]:\n",
        "        if os.path.exists(candidate):\n",
        "            ann_file = candidate\n",
        "            break\n",
        "\n",
        "    if ann_file is None:\n",
        "        print(f\"  ⚠️  No annotation file found for split '{split}' — skipping.\")\n",
        "        return [], [], []\n",
        "\n",
        "    with open(ann_file) as f:\n",
        "        coco = json.load(f)\n",
        "\n",
        "    # Map category id → 0-indexed label\n",
        "    cats       = sorted(coco[\"categories\"], key=lambda c: c[\"id\"])\n",
        "    cat2idx    = {c[\"id\"]: i for i, c in enumerate(cats)}\n",
        "    class_names = [c[\"name\"] for c in cats]\n",
        "\n",
        "    # Map image id → first category label\n",
        "    imgid2label = {}\n",
        "    for ann in coco[\"annotations\"]:\n",
        "        iid = ann[\"image_id\"]\n",
        "        if iid not in imgid2label:\n",
        "            imgid2label[iid] = cat2idx[ann[\"category_id\"]]\n",
        "\n",
        "    # Build path list\n",
        "    img_dir     = os.path.join(dataset_path, split)\n",
        "    imgid2fname = {img[\"id\"]: img[\"file_name\"] for img in coco[\"images\"]}\n",
        "\n",
        "    image_paths, labels = [], []\n",
        "    for iid, label in imgid2label.items():\n",
        "        fname = imgid2fname.get(iid)\n",
        "        if fname is None:\n",
        "            continue\n",
        "        fpath = os.path.join(img_dir, fname)\n",
        "        if os.path.exists(fpath):\n",
        "            image_paths.append(fpath)\n",
        "            labels.append(label)\n",
        "\n",
        "    print(f\"  [{split}] {len(image_paths)} images | classes: {class_names}\")\n",
        "    return image_paths, labels, class_names\n",
        "\n",
        "all_paths, all_labels, class_names = [], [], []\n",
        "for split in [\"train\", \"valid\", \"test\"]:\n",
        "    p, l, c = load_coco_split(DATASET_PATH, split)\n",
        "    all_paths  += p\n",
        "    all_labels += l\n",
        "    if c:\n",
        "        class_names = c\n",
        "\n",
        "all_paths  = np.array(all_paths)\n",
        "all_labels = np.array(all_labels)\n",
        "NUM_CLASSES = len(class_names)\n",
        "print(f\"\\nTotal images: {len(all_paths)} | Classes ({NUM_CLASSES}): {class_names}\")\n",
        "\n",
        "# --- Cell 4: Dataset class & transforms ---\n",
        "import torch\n",
        "import torchvision.transforms as T\n",
        "from torch.utils.data import Dataset, DataLoader, Subset\n",
        "from PIL import Image\n",
        "\n",
        "class FamachaDataset(Dataset):\n",
        "    def __init__(self, paths, labels, transform=None):\n",
        "        self.paths     = paths\n",
        "        self.labels    = labels\n",
        "        self.transform = transform\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.paths)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        img = Image.open(self.paths[idx]).convert(\"RGB\")\n",
        "        if self.transform:\n",
        "            img = self.transform(img)\n",
        "        return img, self.labels[idx]\n",
        "\n",
        "MEAN = [0.485, 0.456, 0.406]\n",
        "STD  = [0.229, 0.224, 0.225]\n",
        "\n",
        "train_tf = T.Compose([\n",
        "    T.Resize((224, 224)),\n",
        "    T.RandomHorizontalFlip(),\n",
        "    T.ColorJitter(0.2, 0.2, 0.2),\n",
        "    T.ToTensor(),\n",
        "    T.Normalize(MEAN, STD),\n",
        "])\n",
        "val_tf = T.Compose([\n",
        "    T.Resize((224, 224)),\n",
        "    T.ToTensor(),\n",
        "    T.Normalize(MEAN, STD),\n",
        "])\n",
        "\n",
        "full_dataset = FamachaDataset(all_paths, all_labels)\n",
        "\n",
        "# --- Cell 5: Nested cross-validation ---\n",
        "import torch.nn as nn\n",
        "import torchvision.models as models\n",
        "from sklearn.model_selection import StratifiedKFold\n",
        "from tqdm import tqdm\n",
        "import copy\n",
        "\n",
        "BATCH      = 8\n",
        "EPOCHS     = 5\n",
        "LR         = 1e-4\n",
        "OUTER_K    = 5\n",
        "INNER_K    = 3\n",
        "DEVICE     = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
        "print(\"Device:\", DEVICE)\n",
        "\n",
        "def build_model(num_classes):\n",
        "    m = models.resnet50(weights=models.ResNet50_Weights.DEFAULT)\n",
        "    m.fc = nn.Linear(m.fc.in_features, num_classes)\n",
        "    return m\n",
        "\n",
        "def train_one_epoch(model, loader, optimizer, criterion, device):\n",
        "    model.train()\n",
        "    total_loss, correct, total = 0, 0, 0\n",
        "    for imgs, labels in loader:\n",
        "        imgs, labels = imgs.to(device), labels.to(device)\n",
        "        optimizer.zero_grad()\n",
        "        out  = model(imgs)\n",
        "        loss = criterion(out, labels)\n",
        "        loss.backward()\n",
        "        optimizer.step()\n",
        "        total_loss += loss.item() * imgs.size(0)\n",
        "        correct    += (out.argmax(1) == labels).sum().item()\n",
        "        total      += imgs.size(0)\n",
        "    return total_loss / total, correct / total\n",
        "\n",
        "def evaluate(model, loader, device):\n",
        "    model.eval()\n",
        "    correct, total = 0, 0\n",
        "    with torch.no_grad():\n",
        "        for imgs, labels in loader:\n",
        "            imgs, labels = imgs.to(device), labels.to(device)\n",
        "            correct += (model(imgs).argmax(1) == labels).sum().item()\n",
        "            total   += imgs.size(0)\n",
        "    return correct / total\n",
        "\n",
        "outer_cv    = StratifiedKFold(n_splits=OUTER_K, shuffle=True, random_state=42)\n",
        "inner_cv    = StratifiedKFold(n_splits=INNER_K, shuffle=True, random_state=7)\n",
        "outer_accs  = []\n",
        "\n",
        "print(f\"\\n{'='*60}\")\n",
        "print(f\"ResNet-50 | Nested CV  (outer={OUTER_K}, inner={INNER_K})\")\n",
        "print(f\"{'='*60}\")\n",
        "\n",
        "for outer_fold, (trainval_idx, test_idx) in enumerate(\n",
        "        outer_cv.split(all_paths, all_labels), 1):\n",
        "\n",
        "    print(f\"\\n── Outer Fold {outer_fold}/{OUTER_K} ──\")\n",
        "    tv_paths, tv_labels = all_paths[trainval_idx], all_labels[trainval_idx]\n",
        "    te_paths, te_labels = all_paths[test_idx],     all_labels[test_idx]\n",
        "\n",
        "    # ---- Inner CV (validation / model selection) ----\n",
        "    inner_val_accs = []\n",
        "    for inner_fold, (tr_idx, val_idx) in enumerate(\n",
        "            inner_cv.split(tv_paths, tv_labels), 1):\n",
        "\n",
        "        tr_ds  = FamachaDataset(tv_paths[tr_idx],  tv_labels[tr_idx],  train_tf)\n",
        "        val_ds = FamachaDataset(tv_paths[val_idx], tv_labels[val_idx], val_tf)\n",
        "        tr_ld  = DataLoader(tr_ds,  batch_size=BATCH, shuffle=True,  num_workers=2)\n",
        "        val_ld = DataLoader(val_ds, batch_size=BATCH, shuffle=False, num_workers=2)\n",
        "\n",
        "        model     = build_model(NUM_CLASSES).to(DEVICE)\n",
        "        optimizer = torch.optim.Adam(model.parameters(), lr=LR)\n",
        "        criterion = nn.CrossEntropyLoss()\n",
        "\n",
        "        for ep in range(1, EPOCHS + 1):\n",
        "            tr_loss, tr_acc = train_one_epoch(model, tr_ld, optimizer, criterion, DEVICE)\n",
        "\n",
        "        val_acc = evaluate(model, val_ld, DEVICE)\n",
        "        inner_val_accs.append(val_acc)\n",
        "        print(f\"   Inner {inner_fold}/{INNER_K} → Val Acc: {val_acc:.4f}\")\n",
        "\n",
        "    print(f\"   Inner mean Val Acc: {np.mean(inner_val_accs):.4f} ± {np.std(inner_val_accs):.4f}\")\n",
        "\n",
        "    # ---- Retrain on full trainval, evaluate on held-out test ----\n",
        "    full_tr_ds = FamachaDataset(tv_paths, tv_labels, train_tf)\n",
        "    te_ds      = FamachaDataset(te_paths, te_labels, val_tf)\n",
        "    full_tr_ld = DataLoader(full_tr_ds, batch_size=BATCH, shuffle=True,  num_workers=2)\n",
        "    te_ld      = DataLoader(te_ds,      batch_size=BATCH, shuffle=False, num_workers=2)\n",
        "\n",
        "    model     = build_model(NUM_CLASSES).to(DEVICE)\n",
        "    optimizer = torch.optim.Adam(model.parameters(), lr=LR)\n",
        "    criterion = nn.CrossEntropyLoss()\n",
        "\n",
        "    for ep in tqdm(range(1, EPOCHS + 1), desc=f\"  Outer {outer_fold} retraining\"):\n",
        "        train_one_epoch(model, full_tr_ld, optimizer, criterion, DEVICE)\n",
        "\n",
        "    test_acc = evaluate(model, te_ld, DEVICE)\n",
        "    outer_accs.append(test_acc)\n",
        "    print(f\"  ✅ Outer Fold {outer_fold} Test Acc: {test_acc:.4f}\")\n",
        "\n",
        "print(f\"\\n{'='*60}\")\n",
        "print(f\"ResNet-50 Nested CV Results (5 outer folds)\")\n",
        "print(f\"  Fold accs : {[f'{a:.4f}' for a in outer_accs]}\")\n",
        "print(f\"  Mean ± Std: {np.mean(outer_accs):.4f} ± {np.std(outer_accs):.4f}\")\n",
        "print(f\"{'='*60}\")"
      ]
    },
